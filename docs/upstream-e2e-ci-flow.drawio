<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="30.2.6">
  <diagram name="NocoBase E2E CI Flow">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="NocoBase E2E CI 触发、分支与 targets 解析框图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=28;fontStyle=1;fontColor=#0f172a;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1120" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="核心职责：2013xile/nocobase-ci 负责上游调度和解析；Charls-Wu/nocobase-e2e-ci 只负责执行测试。" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontColor=#475569;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="1220" y="24" width="880" height="36" as="geometry" />
        </mxCell>
        <mxCell id="c_source" value="1. 触发来源：仓库、分支、提交类型" style="swimlane;html=1;startSize=38;rounded=1;whiteSpace=wrap;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;fontStyle=1;fontSize=16;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="620" height="740" as="geometry" />
        </mxCell>
        <mxCell id="s_counts" value="总览&#xa;源码仓类型：3 类&#xa;提交/触发类型：6 种&#xa;E2E 分支：main / next / develop" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0f172a;fontSize=14;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_source">
          <mxGeometry x="30" y="60" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s_main" value="主仓&#xa;nocobase/nocobase&#xa;&#xa;PR：develop-9956-nocobase-&#xa;分支构建：develop--nocobase-&#xa;&#xa;changed files：PR API / 最新 commit" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_source">
          <mxGeometry x="30" y="190" width="270" height="170" as="geometry" />
        </mxCell>
        <mxCell id="s_pro" value="Pro 插件合集仓&#xa;nocobase/pro-plugins&#xa;&#xa;PR：main--pro-plugins-520&#xa;分支构建：develop--pro-plugins-&#xa;&#xa;changed files：PR API / 最新 commit" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_source">
          <mxGeometry x="320" y="190" width="270" height="170" as="geometry" />
        </mxCell>
        <mxCell id="s_plugin" value="独立插件仓&#xa;nocobase/plugin-xxx&#xa;&#xa;PR：next--plugin-email-manager-113&#xa;分支构建：develop--plugin-auth-ldap-&#xa;&#xa;target 默认等于仓库名" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_source">
          <mxGeometry x="30" y="390" width="270" height="180" as="geometry" />
        </mxCell>
        <mxCell id="s_branch" value="E2E 分支规则&#xa;&#xa;e2e_ref = inputs.branch&#xa;只支持：main / next / develop&#xa;&#xa;PR 源分支不参与选择&#xa;v1 或其他分支：跳过 E2E" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#fae8ff;strokeColor=#a855f7;fontColor=#0f172a;fontSize=13;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_source">
          <mxGeometry x="320" y="390" width="270" height="180" as="geometry" />
        </mxCell>
        <mxCell id="s_to2013" value="这些触发最终进入&#xa;2013 的 Build pro image workflow_dispatch" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#ffffff;strokeColor=#64748b;fontColor=#334155;fontSize=14;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_source">
          <mxGeometry x="30" y="615" width="560" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c_2013" value="2. 2013xile/nocobase-ci：构建镜像 + 上游解析 + 调度" style="swimlane;html=1;startSize=38;rounded=1;whiteSpace=wrap;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontStyle=1;fontSize=16;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="700" height="740" as="geometry" />
        </mxCell>
        <mxCell id="w_inputs" value="build-pro-image 输入&#xa;&#xa;branch&#xa;repository&#xa;nocobase_pr_number&#xa;pro_plugin / pro_pr_number&#xa;checkRunId" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#ffedd5;strokeColor=#f97316;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_2013">
          <mxGeometry x="30" y="85" width="300" height="145" as="geometry" />
        </mxCell>
        <mxCell id="w_image" value="构建并上传镜像&#xa;&#xa;prepare-meta 生成 imageTag&#xa;assemble-image 构建镜像&#xa;上传到镜像仓库&#xa;&#xa;例：develop / next / pr-8743 / pr-520-pro" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#fed7aa;strokeColor=#ea580c;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_2013">
          <mxGeometry x="370" y="85" width="300" height="145" as="geometry" />
        </mxCell>
        <mxCell id="w_resolve" value="resolve-e2e-targets（正式逻辑落点）&#xa;&#xa;1. 用 GitHub App token 读取源码仓&#xa;2. PR 用 Pull Request files API&#xa;3. 分支构建用 branch 最新 commit files&#xa;4. checkout nocobase/e2e@e2e_ref 读取可执行包&#xa;5. 输出 target_input / should_run / e2e_ref / missingTargets" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#ffffff;strokeColor=#ea580c;fontColor=#0f172a;fontSize=13;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_2013">
          <mxGeometry x="30" y="285" width="640" height="190" as="geometry" />
        </mxCell>
        <mxCell id="w_dispatch" value="dispatch-e2e&#xa;&#xa;条件：&#xa;assemble-image 成功&#xa;should_run = true&#xa;&#xa;触发 E2E worker" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#fb923c;strokeColor=#c2410c;fontColor=#111827;fontSize=14;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_2013">
          <mxGeometry x="205" y="520" width="290" height="120" as="geometry" />
        </mxCell>
        <mxCell id="w_rollout" value="接入建议：第一阶段 PR 只打印解析结果，不触发真实 E2E；观察通过后第二阶段再开启 dispatch。" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#fef9c3;strokeColor=#ca8a04;fontColor=#713f12;fontSize=13;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_2013">
          <mxGeometry x="30" y="675" width="640" height="45" as="geometry" />
        </mxCell>
        <mxCell id="c_e2e" value="3. E2E 执行：worker + 私有测试仓" style="swimlane;html=1;startSize=38;rounded=1;whiteSpace=wrap;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#0f172a;fontStyle=1;fontSize=16;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="1440" y="90" width="720" height="740" as="geometry" />
        </mxCell>
        <mxCell id="e_worker" value="Charls-Wu/nocobase-e2e-ci&#xa;公开 E2E worker&#xa;&#xa;输入：&#xa;targets&#xa;nocobase_version = imageTag&#xa;e2e_ref = main / next / develop&#xa;dry_run = false" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#0f172a;fontSize=13;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_e2e">
          <mxGeometry x="30" y="85" width="310" height="190" as="geometry" />
        </mxCell>
        <mxCell id="e_repo" value="nocobase/e2e&#xa;私有测试仓&#xa;&#xa;只维护长期分支：&#xa;main&#xa;next&#xa;develop&#xa;&#xa;packages/* 中带 scripts.test:e2e 的包才可执行" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=10;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_e2e">
          <mxGeometry x="375" y="85" width="315" height="190" as="geometry" />
        </mxCell>
        <mxCell id="e_run" value="执行测试&#xa;&#xa;checkout nocobase/e2e@e2e_ref&#xa;targets=包名：跑指定包&#xa;targets=包A,包B：matrix 并行跑&#xa;targets=*：跑该分支全部可执行包&#xa;max-parallel=10，fail-fast=false" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#ffffff;strokeColor=#16a34a;fontColor=#0f172a;fontSize=13;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_e2e">
          <mxGeometry x="30" y="330" width="660" height="135" as="geometry" />
        </mxCell>
        <mxCell id="e_notify" value="结果产物&#xa;&#xa;每个包上传：playwright-report / test-results / e2e-result&#xa;notify job 汇总所有包结果&#xa;飞书发送一条汇总通知，包含 GitHub Actions run 和 artifact 链接" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#bbf7d0;strokeColor=#16a34a;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_e2e">
          <mxGeometry x="30" y="520" width="660" height="135" as="geometry" />
        </mxCell>
        <mxCell id="e_boundary" value="边界：worker 不判断 changed files，不决定 targets；它只执行上游传来的参数。" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#991b1b;fontSize=13;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_e2e">
          <mxGeometry x="30" y="685" width="660" height="35" as="geometry" />
        </mxCell>
        <mxCell id="c_rules" value="4. targets 解析规则：changed files 到 target_input" style="swimlane;html=1;startSize=38;rounded=1;whiteSpace=wrap;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;fontStyle=1;fontSize=16;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="40" y="870" width="2120" height="470" as="geometry" />
        </mxCell>
        <mxCell id="r_main" value="主仓 nocobase/nocobase&#xa;&#xa;packages/plugins/@nocobase/&lt;plugin&gt;/**&#xa;  → &lt;plugin&gt;&#xa;&#xa;packages/core/**、构建、公共运行时代码&#xa;  → *&#xa;&#xa;例：plugin-block-iframe → plugin-block-iframe" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_rules">
          <mxGeometry x="30" y="75" width="485" height="230" as="geometry" />
        </mxCell>
        <mxCell id="r_pro" value="pro-plugins&#xa;&#xa;@nocobase/plugin-action-import-pro/src/**&#xa;  → plugin-action-import-pro&#xa;&#xa;external-db-data-source/src/**&#xa;  → external-db-data-source&#xa;&#xa;根级 package.json / 公共影响面不明确的变化&#xa;  → *" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_rules">
          <mxGeometry x="545" y="75" width="485" height="230" as="geometry" />
        </mxCell>
        <mxCell id="r_plugin" value="独立插件仓 nocobase/plugin-xxx&#xa;&#xa;任意非忽略代码变更&#xa;  → plugin-xxx&#xa;&#xa;例：nocobase/plugin-backups&#xa;  → plugin-backups&#xa;&#xa;如果 e2e 仓没有对应可执行包&#xa;  → missingTargets，不触发" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_rules">
          <mxGeometry x="1060" y="75" width="485" height="230" as="geometry" />
        </mxCell>
        <mxCell id="r_filter" value="通用过滤和执行规则&#xa;&#xa;docs/**、.github/**、README.md、*.md、.node-version&#xa;  → 不触发 E2E&#xa;&#xa;target 不存在或没有 scripts.test:e2e&#xa;  → missingTargets，不触发该包&#xa;&#xa;target_input=*&#xa;  → 跑 e2e_ref 下所有可执行包" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=12;fillColor=#ede9fe;strokeColor=#7c3aed;fontColor=#0f172a;fontSize=13;fontFamily=Arial;" vertex="1" parent="c_rules">
          <mxGeometry x="1575" y="75" width="515" height="230" as="geometry" />
        </mxCell>
        <mxCell id="r_output" value="解析输出到 E2E worker：target_input = 包名 / 包A,包B / *；should_run 控制是否 dispatch；e2e_ref 始终来自 base branch main / next / develop。" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=12;fillColor=#ffffff;strokeColor=#64748b;fontColor=#0f172a;fontSize=15;fontStyle=1;fontFamily=Arial;" vertex="1" parent="c_rules">
          <mxGeometry x="30" y="345" width="2060" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edge_source_2013" value="workflow_dispatch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#334155;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="s_to2013" target="w_inputs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_inputs_image" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="w_inputs" target="w_image">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_inputs_resolve" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="w_inputs" target="w_resolve">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_image_dispatch" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="w_image" target="w_dispatch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_resolve_dispatch" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="w_resolve" target="w_dispatch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_dispatch_worker" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=3;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="w_dispatch" target="e_worker">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1420" y="640" />
              <mxPoint x="1420" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="edge_worker_repo" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0284c7;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="e_worker" target="e_repo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_worker_run" value="targets / imageTag" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="e_worker" target="e_run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_repo_run" value="packages list" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0284c7;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="e_repo" target="e_run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_run_notify" value="package results" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;fontSize=12;labelBackgroundColor=#ffffff;fontFamily=Arial;" edge="1" parent="1" source="e_run" target="e_notify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
